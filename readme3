Form1.cs


using System;
using System.Data;
using System.Linq;
using System.Windows.Forms;

namespace MarketYonetim
{
    public partial class Form1 : Form
    {
        Veritabani db = new Veritabani();
        int seciliMusteriID = -1;
        int seciliUrunID = -1;
        int seciliSiparisID = -1;

        // =============================================
        // NOT: Aşağıdaki kontroller Designer'da oluşturulacak.
        // Designer'da şu kontrolleri ekleyin:
        //
        // TabControl: tabControl1 (3 sekme: Müşteriler, Ürünler, Siparişler)
        //
        // --- Müşteriler Sekmesi ---
        // TextBox: txtAd, txtSoyad, txtTelefon, txtEposta, txtMusteriAra
        // Button:  btnMusteriEkle, btnMusteriGuncelle, btnMusteriSil
        // DataGridView: dgvMusteri
        //
        // --- Ürünler Sekmesi ---
        // TextBox: txtUrunAdi, txtKategori, txtFiyat, txtStok, txtUrunAra
        // Button:  btnUrunEkle, btnUrunGuncelle, btnUrunSil
        // DataGridView: dgvUrun
        //
        // --- Siparişler Sekmesi ---
        // ComboBox: cmbMusteri, cmbUrun
        // TextBox:  txtAdet, txtSiparisAra
        // Button:   btnSiparisEkle, btnSiparisSil
        // DataGridView: dgvSiparis
        // =============================================

        public Form1()
        {
            InitializeComponent();
        }

        // --- FORM YÜKLEME ---
        private void Form1_Load(object sender, EventArgs e)
        {
            Listele();
        }

        private void Listele()
        {
            dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Listele);
            dgvUrun.DataSource = db.UrunIslem(IslemTipi.Listele);
            dgvSiparis.DataSource = db.SiparisIslem(IslemTipi.Listele);

            // ComboBox'ları doldur
            cmbMusteri.DataSource = db.MusteriIslem(IslemTipi.Listele);
            cmbMusteri.DisplayMember = "Ad";
            cmbMusteri.ValueMember = "MusteriID";

            cmbUrun.DataSource = db.UrunIslem(IslemTipi.Listele);
            cmbUrun.DisplayMember = "UrunAdi";
            cmbUrun.ValueMember = "UrunID";
        }

        // ==================
        // MÜŞTERİ İŞLEMLERİ
        // ==================

        // CellClick → TextBox'lara yükle
        private void dgvMusteri_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            var row = dgvMusteri.Rows[e.RowIndex];
            seciliMusteriID = Convert.ToInt32(row.Cells["MusteriID"].Value);
            txtAd.Text = row.Cells["Ad"].Value.ToString();
            txtSoyad.Text = row.Cells["Soyad"].Value.ToString();
            txtTelefon.Text = row.Cells["Telefon"].Value.ToString();
            txtEposta.Text = row.Cells["Eposta"].Value.ToString();
        }

        // Ekle
        private void btnMusteriEkle_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtAd.Text) || string.IsNullOrWhiteSpace(txtSoyad.Text))
            {
                MessageBox.Show("Ad ve Soyad boş olamaz.");
                return;
            }
            if (!txtTelefon.Text.All(char.IsDigit) || txtTelefon.Text.Length != 11)
            {
                MessageBox.Show("Telefon 11 haneli rakam olmalı.");
                return;
            }

            dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Ekle,
                txtAd.Text, txtSoyad.Text, txtTelefon.Text, txtEposta.Text);
            Temizle();
            MessageBox.Show("Müşteri eklendi.");
        }

        // Güncelle
        private void btnMusteriGuncelle_Click(object sender, EventArgs e)
        {
            if (seciliMusteriID == -1) { MessageBox.Show("Tablodan bir müşteri seçin."); return; }

            dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Guncelle,
                txtAd.Text, txtSoyad.Text, txtTelefon.Text, txtEposta.Text, seciliMusteriID);
            Temizle();
            MessageBox.Show("Müşteri güncellendi.");
        }

        // Sil
        private void btnMusteriSil_Click(object sender, EventArgs e)
        {
            if (seciliMusteriID == -1) { MessageBox.Show("Tablodan bir müşteri seçin."); return; }

            if (MessageBox.Show("Silmek istediğinize emin misiniz?", "Onay",
                MessageBoxButtons.YesNo) == DialogResult.Yes)
            {
                dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Sil, seciliMusteriID);
                Temizle();
            }
        }

        // TextChanged → Anlık arama
        private void txtMusteriAra_TextChanged(object sender, EventArgs e)
        {
            if (txtMusteriAra.Text == "")
                dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Listele);
            else
                dgvMusteri.DataSource = db.MusteriIslem(IslemTipi.Ara, txtMusteriAra.Text);
        }

        private void Temizle()
        {
            txtAd.Clear(); txtSoyad.Clear(); txtTelefon.Clear(); txtEposta.Clear();
            seciliMusteriID = -1;
            Listele();
        }

        // ==============
        // ÜRÜN İŞLEMLERİ
        // ==============

        private void dgvUrun_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            var row = dgvUrun.Rows[e.RowIndex];
            seciliUrunID = Convert.ToInt32(row.Cells["UrunID"].Value);
            txtUrunAdi.Text = row.Cells["UrunAdi"].Value.ToString();
            txtKategori.Text = row.Cells["Kategori"].Value.ToString();
            txtFiyat.Text = row.Cells["Fiyat"].Value.ToString();
            txtStok.Text = row.Cells["StokMiktari"].Value.ToString();
        }

        private void btnUrunEkle_Click(object sender, EventArgs e)
        {
            if (string.IsNullOrWhiteSpace(txtUrunAdi.Text)) { MessageBox.Show("Ürün adı boş olamaz."); return; }

            dgvUrun.DataSource = db.UrunIslem(IslemTipi.Ekle,
                txtUrunAdi.Text, txtKategori.Text, Convert.ToDecimal(txtFiyat.Text), Convert.ToInt32(txtStok.Text));
            UrunTemizle();
            MessageBox.Show("Ürün eklendi.");
        }

        private void btnUrunGuncelle_Click(object sender, EventArgs e)
        {
            if (seciliUrunID == -1) { MessageBox.Show("Tablodan bir ürün seçin."); return; }

            dgvUrun.DataSource = db.UrunIslem(IslemTipi.Guncelle,
                txtUrunAdi.Text, txtKategori.Text, Convert.ToDecimal(txtFiyat.Text), Convert.ToInt32(txtStok.Text), seciliUrunID);
            UrunTemizle();
            MessageBox.Show("Ürün güncellendi.");
        }

        private void btnUrunSil_Click(object sender, EventArgs e)
        {
            if (seciliUrunID == -1) { MessageBox.Show("Tablodan bir ürün seçin."); return; }

            if (MessageBox.Show("Silmek istediğinize emin misiniz?", "Onay",
                MessageBoxButtons.YesNo) == DialogResult.Yes)
            {
                dgvUrun.DataSource = db.UrunIslem(IslemTipi.Sil, seciliUrunID);
                UrunTemizle();
            }
        }

        private void txtUrunAra_TextChanged(object sender, EventArgs e)
        {
            if (txtUrunAra.Text == "")
                dgvUrun.DataSource = db.UrunIslem(IslemTipi.Listele);
            else
                dgvUrun.DataSource = db.UrunIslem(IslemTipi.Ara, txtUrunAra.Text);
        }

        private void UrunTemizle()
        {
            txtUrunAdi.Clear(); txtKategori.Clear(); txtFiyat.Clear(); txtStok.Clear();
            seciliUrunID = -1;
            Listele();
        }

        // ==================
        // SİPARİŞ İŞLEMLERİ
        // ==================

        private void dgvSiparis_CellClick(object sender, DataGridViewCellEventArgs e)
        {
            if (e.RowIndex < 0) return;
            seciliSiparisID = Convert.ToInt32(dgvSiparis.Rows[e.RowIndex].Cells["SiparisID"].Value);
        }

        private void btnSiparisEkle_Click(object sender, EventArgs e)
        {
            if (!int.TryParse(txtAdet.Text, out int adet) || adet <= 0)
            {
                MessageBox.Show("Geçerli bir adet girin.");
                return;
            }

            dgvSiparis.DataSource = db.SiparisIslem(IslemTipi.Ekle,
                cmbMusteri.SelectedValue, cmbUrun.SelectedValue, adet);
            txtAdet.Clear();
            MessageBox.Show("Sipariş eklendi.");
        }

        private void btnSiparisSil_Click(object sender, EventArgs e)
        {
            if (seciliSiparisID == -1) { MessageBox.Show("Tablodan bir sipariş seçin."); return; }

            if (MessageBox.Show("Silmek istediğinize emin misiniz?", "Onay",
                MessageBoxButtons.YesNo) == DialogResult.Yes)
            {
                dgvSiparis.DataSource = db.SiparisIslem(IslemTipi.Sil, seciliSiparisID);
                seciliSiparisID = -1;
            }
        }

        private void txtSiparisAra_TextChanged(object sender, EventArgs e)
        {
            if (txtSiparisAra.Text == "")
                dgvSiparis.DataSource = db.SiparisIslem(IslemTipi.Listele);
            else
                dgvSiparis.DataSource = db.SiparisIslem(IslemTipi.Ara, txtSiparisAra.Text);
        }
    }
}
