
         Veritabani.cs


using System;
using System.Data;
using Microsoft.Data.SqlClient;

namespace MarketYonetim
{
    public enum IslemTipi
    {
        Listele, Ekle, Sil, Guncelle, Ara
    }

    public class Veritabani
    {
    private string cs = @"Server=(localdb)\MSSQLLocalDB;Database=MarketDB;Trusted_Connection=True;TrustServerCertificate=True;";

        // SELECT → DataTable döndürür
        public DataTable TabloDoldur(string sql, params object[] p)
        {
            DataTable dt = new DataTable();
            using (SqlConnection conn = new SqlConnection(cs))
            using (SqlCommand cmd = new SqlCommand(sql, conn))
            {
                for (int i = 0; i < p.Length; i++)
                    cmd.Parameters.AddWithValue("@p" + i, p[i]);

                conn.Open();
                new SqlDataAdapter(cmd).Fill(dt);
            }
            return dt;
        }

        // INSERT, UPDATE, DELETE → etkilenen satır sayısı
        public int SorguCalistir(string sql, params object[] p)
        {
            using (SqlConnection conn = new SqlConnection(cs))
            using (SqlCommand cmd = new SqlCommand(sql, conn))
            {
                for (int i = 0; i < p.Length; i++)
                    cmd.Parameters.AddWithValue("@p" + i, p[i]);

                conn.Open();
                return cmd.ExecuteNonQuery();
            }
        }

        // --- MÜŞTERİ İŞLEMLERİ ---
        public DataTable MusteriIslem(IslemTipi tip, params object[] v)
        {
            switch (tip)
            {
                case IslemTipi.Listele:
                    return TabloDoldur("SELECT * FROM Musteriler");

                case IslemTipi.Ekle:
                    SorguCalistir("INSERT INTO Musteriler (Ad,Soyad,Telefon,Eposta) VALUES (@p0,@p1,@p2,@p3)",
                        v[0], v[1], v[2], v[3]);
                    return MusteriIslem(IslemTipi.Listele);

                case IslemTipi.Guncelle:
                    SorguCalistir("UPDATE Musteriler SET Ad=@p0,Soyad=@p1,Telefon=@p2,Eposta=@p3 WHERE MusteriID=@p4",
                        v[0], v[1], v[2], v[3], v[4]);
                    return MusteriIslem(IslemTipi.Listele);

                case IslemTipi.Sil:
                    SorguCalistir("DELETE FROM Musteriler WHERE MusteriID=@p0", v[0]);
                    return MusteriIslem(IslemTipi.Listele);

                case IslemTipi.Ara:
                    string a = "%" + v[0] + "%";
                    return TabloDoldur("SELECT * FROM Musteriler WHERE Ad LIKE @p0 OR Soyad LIKE @p1", a, a);

                default: return new DataTable();
            }
        }

        // --- ÜRÜN İŞLEMLERİ ---
        public DataTable UrunIslem(IslemTipi tip, params object[] v)
        {
            switch (tip)
            {
                case IslemTipi.Listele:
                    return TabloDoldur("SELECT * FROM Urunler");

                case IslemTipi.Ekle:
                    SorguCalistir("INSERT INTO Urunler (UrunAdi,Kategori,Fiyat,StokMiktari) VALUES (@p0,@p1,@p2,@p3)",
                        v[0], v[1], v[2], v[3]);
                    return UrunIslem(IslemTipi.Listele);

                case IslemTipi.Guncelle:
                    SorguCalistir("UPDATE Urunler SET UrunAdi=@p0,Kategori=@p1,Fiyat=@p2,StokMiktari=@p3 WHERE UrunID=@p4",
                        v[0], v[1], v[2], v[3], v[4]);
                    return UrunIslem(IslemTipi.Listele);

                case IslemTipi.Sil:
                    SorguCalistir("DELETE FROM Urunler WHERE UrunID=@p0", v[0]);
                    return UrunIslem(IslemTipi.Listele);

                case IslemTipi.Ara:
                    string a = "%" + v[0] + "%";
                    return TabloDoldur("SELECT * FROM Urunler WHERE UrunAdi LIKE @p0 OR Kategori LIKE @p1", a, a);

                default: return new DataTable();
            }
        }

        // --- SİPARİŞ İŞLEMLERİ (INNER JOIN ile) ---
        public DataTable SiparisIslem(IslemTipi tip, params object[] v)
        {
            string joinSql = @"SELECT s.SiparisID, m.Ad+' '+m.Soyad AS Musteri, u.UrunAdi, 
                               s.Adet, u.Fiyat, (s.Adet*u.Fiyat) AS Tutar, s.SiparisTarihi
                               FROM Siparisler s
                               INNER JOIN Musteriler m ON s.MusteriID=m.MusteriID
                               INNER JOIN Urunler u ON s.UrunID=u.UrunID";

            switch (tip)
            {
                case IslemTipi.Listele:
                    return TabloDoldur(joinSql);

                case IslemTipi.Ekle:
                    SorguCalistir("INSERT INTO Siparisler (MusteriID,UrunID,Adet) VALUES (@p0,@p1,@p2)",
                        v[0], v[1], v[2]);
                    return SiparisIslem(IslemTipi.Listele);

                case IslemTipi.Sil:
                    SorguCalistir("DELETE FROM Siparisler WHERE SiparisID=@p0", v[0]);
                    return SiparisIslem(IslemTipi.Listele);

                case IslemTipi.Ara:
                    string a = "%" + v[0] + "%";
                    return TabloDoldur(joinSql + " WHERE m.Ad LIKE @p0 OR u.UrunAdi LIKE @p1", a, a);

                default: return new DataTable();
            }
        }
    }
}






















