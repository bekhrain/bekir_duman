Zor Seviye Soru Senaryosu: "Banka Hesabı Simülasyonu"
Soru: Bir banka hesabı simülasyonu yapınız. Hesaba aynı anda iki farklı Thread üzerinden para yatırılacaktır.

Thread 1: Hesaba 1000 defa 1 TL yatıracak.

Thread 2: Hesaba 1000 defa 1 TL yatıracak.

lock mekanizması kullanmadan kodu yazıp sonucun neden her seferinde 2000 çıkmadığını (Race Condition) açıklayınız.

lock kullanarak veri güvenliğini sağlayınız ve sonucun tam 2000 çıkmasını garanti ediniz.

Kod Çözümü (C#)
C#
using System;
using System.Threading;

class BankaHesabi
{
    private int bakiye = 0;
    private static object kilitNesnesi = new object(); // Kritik bölgeyi korumak için

    public void ParaYatir()
    {
        for (int i = 0; i < 1000; i++)
        {
            // ZOR KISIM: Eğer buradaki lock'ı kaldırırsanız, 
            // iki thread aynı anda bakiyeyi okuyup üzerine yazar ve veri kaybolur.
            lock (kilitNesnesi) 
            {
                bakiye = bakiye + 1;
            }
            
            // İşlemci geçişlerini zorlamak ve hatayı görmek için çok kısa bekleme
            // Thread.Sleep(1); 
        }
    }

    public int BakiyeGetir() => bakiye;
}

class Program
{
    static void Main()
    {
        BankaHesabi hesap = new BankaHesabi();

        // İki farklı thread aynı metodu çalıştırıyor
        Thread t1 = new Thread(hesap.ParaYatir);
        Thread t2 = new Thread(hesap.ParaYatir);

        t1.Start();
        t2.Start();

        // ZOR KISIM: Join kullanmazsanız, threadler bitmeden 
        // ekrana sonucu yazdırır ve sonucu 0 veya çok küçük görürsünüz.
        t1.Join(); 
        t2.Join();

        Console.WriteLine("Sonuç Bakiye: " + hesap.BakiyeGetir());
        Console.ReadLine();
    }
}














