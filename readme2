Zor Senaryo: "Paralel Dizi Toplamı ve Senkronizasyon"
Soru: 1'den 2000'e kadar olan sayıların toplamını hesaplayan bir program yazmanız isteniyor. Ancak işlemciyi yormamak (?) için bu işi iki parçaya bölmelisiniz:

Thread 1: 1 ile 1000 arasındaki sayıları toplayıp ortak bir toplam değişkenine ekleyecek.

Thread 2: 1001 ile 2000 arasındaki sayıları toplayıp aynı ortak toplam değişkenine ekleyecek.

Kısıtlar: * Her iki thread de aynı toplam değişkenini kullanmalı (Race Condition riski).

Ana program (Main), thread'ler işini bitirmeden sonucu ekrana yazdırmamalı.

Her toplama işleminden sonra Thread.Sleep(1) yaparak işlemci geçişlerini (context switch) zorlamalısın.

Çözüm Kodu (C#)
C#
using System;
using System.Threading;

class Program
{
    static int genelToplam = 0; // Ortak kaynak
    static object kilit = new object(); // Senkronizasyon anahtarı

    static void Main()
    {
        // Thread'lere parametre gönderiyoruz (Başlangıç ve Bitiş değerleri)
        Thread t1 = new Thread(() => Topla(1, 1000));
        Thread t2 = new Thread(() => Topla(1001, 2000));

        t1.Start();
        t2.Start();

        // KRİTİK NOKTA: Join kullanılmazsa ana thread toplama bitmeden 0 yazar.
        t1.Join(); 
        t2.Join();

        Console.WriteLine($"Hesaplanan Toplam: {genelToplam}");
        // Matematiksel sağlama: (n*(n+1))/2 => (2000*2001)/2 = 2.001.000
        Console.ReadLine();
    }

    static void Topla(int baslangic, int bitis)
    {
        int araToplam = 0;
        for (int i = baslangic; i <= bitis; i++)
        {
            araToplam += i;
        }

        // KRİTİK BÖLGE: Ortak değişkene yazarken kilitleme şart!
        lock (kilit)
        {
            // Eğer lock olmazsa, iki thread aynı anda eklemeye çalışırken
            // biri diğerinin sonucunu silebilir.
            genelToplam += araToplam;
        }
    }
}


















Senaryo: "Sinema Bileti Satış Sistemi"
Bir sinema salonunda sadece 10 adet boş koltuk var. İki farklı bilet gişesi (Thread 1 ve Thread 2) aynı anda bilet satmaya çalışıyor. Eğer senkronizasyon (lock) kullanmazsan, sistem aslında olmayan koltukları da satmaya çalışabilir (Race Condition).

Kod Çözümü (C#)
C#
using System;
using System.Threading;

class SinemaSistemi
{
    private int toplamBilet = 10; // Paylaşılan kaynak
    private static object kilit = new object(); // Kilitleme nesnesi

    public void BiletSat(string giseAdi)
    {
        while (true)
        {
            // Kritik Bölge Başlangıcı
            lock (kilit) 
            {
                if (toplamBilet > 0)
                {
                    // İşlemi yavaşlatıp hatayı tetiklemek için kısa bir bekleme
                    Thread.Sleep(100); 
                    
                    toplamBilet--;
                    Console.WriteLine($"{giseAdi} bilet sattı. Kalan bilet: {toplamBilet}");
                }
                else
                {
                    Console.WriteLine($"{giseAdi}: Biletler tükendi!");
                    break; 
                }
            }
            // Kritik Bölge Bitişi
            
            // Gişeler arası geçişi simüle etmek için dışarıda kısa bekleme
            Thread.Sleep(10); 
        }
    }
}

class Program
{
    static void Main()
    {
        SinemaSistemi sinema = new SinemaSistemi();

        Thread gise1 = new Thread(() => sinema.BiletSat("Gişe-1"));
        Thread gise2 = new Thread(() => sinema.BiletSat("Gişe-2"));

        gise1.Start();
        gise2.Start();

        gise1.Join();
        gise2.Join();

        Console.WriteLine("Satış işlemi tamamlandı.");
        Console.ReadLine();
    }
}







































