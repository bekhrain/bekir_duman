Senaryo 2 — İki Thread 300ms Arayla

"İki farklı thread oluşturup 300ms arayla çalıştırın, sıranın değiştiğini gözlemleyin."
csharpusing System;
using System.Threading;

class Program
{
    static void Main()
    {
        Thread t1 = new Thread(() =>
        {
            for (int i = 1; i <= 5; i++)
            {
                Console.WriteLine($"Thread 1 → Adım {i}");
                Thread.Sleep(300);
            }
        });

        Thread t2 = new Thread(() =>
        {
            for (int i = 1; i <= 5; i++)
            {
                Console.WriteLine($"Thread 2 → Adım {i}");
                Thread.Sleep(300);
            }
        });

        t1.Start();
        Thread.Sleep(300); // t2'yi 300ms geç başlat
        t2.Start();

        t1.Join();
        t2.Join();

        Console.WriteLine("Tüm thread'ler tamamlandı.");
        Console.ReadLine();
    }
}


















