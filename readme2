using System;
using System.Collections.Generic;

namespace UrunEnvanter
{
    class Urun
    {
        public int UrunId { get; set; }
        public string Ad { get; set; }
        public string Kategori { get; set; }
        public double Fiyat { get; set; }
        public int Stok { get; set; }

        public Urun(int id, string ad, string kategori, double fiyat, int stok)
        {
            UrunId = id;
            Ad = ad;
            Kategori = kategori;
            Fiyat = fiyat;
            Stok = stok;
        }
    }

    class Program
    {
        static List<Urun> urunler = new List<Urun>();

        static void Main(string[] args)
        {
            urunler.Add(new Urun(1, "Laptop",         "Elektronik", 25999.90, 15));
            urunler.Add(new Urun(2, "Kablosuz Mouse", "Elektronik",   349.90, 80));
            urunler.Add(new Urun(3, "Mekanik Klavye", "Elektronik",   899.00,  8));
            urunler.Add(new Urun(4, "Masa Lambasi",   "Mobilya",      299.00, 40));
            urunler.Add(new Urun(5, "Sandalye",       "Mobilya",     3200.00, 12));
            urunler.Add(new Urun(6, "Not Defteri",    "Kirtasiye",    24.90, 200));
            urunler.Add(new Urun(7, "Tukenmez Kalem", "Kirtasiye",     4.50,  5));
            urunler.Add(new Urun(8, "Monitor",        "Elektronik",  8500.00, 20));
            urunler.Add(new Urun(9, "USB Hub",        "Elektronik",   450.00,  3));

            bool devam = true;

            while (devam)
            {
                Console.WriteLine("\n=== URUN ENVANTER SISTEMI ===");
                Console.WriteLine("1. Tum urunleri listele");
                Console.WriteLine("2. Kategoriye gore listele");
                Console.WriteLine("3. Kritik stok raporu");
                Console.WriteLine("4. En ucuz urun");
                Console.WriteLine("5. Urun ara");
                Console.WriteLine("6. Fiyat guncelle");
                Console.WriteLine("0. Cikis");
                Console.Write("Secim yapiniz: ");

                string secim = Console.ReadLine();

                if (secim == "1")
                {
                    TumunuListele();
                }
                else if (secim == "2")
                {
                    Console.Write("Kategori girin (Elektronik/Mobilya/Kirtasiye): ");
                    string kategori = Console.ReadLine();
                    KategoriyeGoreListele(kategori);
                }
                else if (secim == "3")
                {
                    KritikStokRaporu();
                }
                else if (secim == "4")
                {
                    EnUcuzUrun();
                }
                else if (secim == "5")
                {
                    Console.Write("Aranacak urun adi: ");
                    string kelime = Console.ReadLine();
                    UrunAra(kelime);
                }
                else if (secim == "6")
                {
                    Console.Write("Guncellenecek urun ID: ");
                    string idGirdi = Console.ReadLine();
                    int urunId;
                    if (int.TryParse(idGirdi, out urunId))
                    {
                        FiyatGuncelle(urunId);
                    }
                    else
                    {
                        Console.WriteLine("Gecersiz ID girdiniz.");
                    }
                }
                else if (secim == "0")
                {
                    devam = false;
                    Console.WriteLine("Program sonlandi.");
                }
                else
                {
                    Console.WriteLine("Gecersiz secim!");
                }
            }
        }

        static void TumunuListele()
        {
            Console.WriteLine("\n--- TUM URUNLER ---");

            for (int i = 0; i < urunler.Count; i++)
            {
                Console.WriteLine("ID: " + urunler[i].UrunId + " | Ad: " + urunler[i].Ad + " | Kategori: " + urunler[i].Kategori + " | Fiyat: " + urunler[i].Fiyat + " TL | Stok: " + urunler[i].Stok);
            }
        }

        static void KategoriyeGoreListele(string kategori)
        {
            Console.WriteLine("\n--- " + kategori.ToUpper() + " KATEGORISI ---");

            bool bulundu = false;
            double toplamFiyat = 0;
            int adet = 0;

            for (int i = 0; i < urunler.Count; i++)
            {
                if (urunler[i].Kategori == kategori)
                {
                    Console.WriteLine("Ad: " + urunler[i].Ad + " | Fiyat: " + urunler[i].Fiyat + " TL | Stok: " + urunler[i].Stok);
                    toplamFiyat = toplamFiyat + urunler[i].Fiyat;
                    adet = adet + 1;
                    bulundu = true;
                }
            }

            if (bulundu == false)
            {
                Console.WriteLine("Bu kategoride urun bulunamadi.");
            }
            else
            {
                double ortalama = toplamFiyat / adet;
                Console.WriteLine("Ortalama fiyat: " + Math.Round(ortalama, 2) + " TL");
            }
        }

        static void KritikStokRaporu()
        {
            Console.WriteLine("\n--- KRITIK STOK RAPORU (10 ve alti) ---");

            bool bulundu = false;

            for (int i = 0; i < urunler.Count; i++)
            {
                if (urunler[i].Stok <= 10)
                {
                    Console.WriteLine("Urun: " + urunler[i].Ad + " | Stok: " + urunler[i].Stok + " adet | Fiyat: " + urunler[i].Fiyat + " TL");
                    bulundu = true;
                }
            }

            if (bulundu == false)
            {
                Console.WriteLine("Kritik stok durumu yok.");
            }
        }

        static void EnUcuzUrun()
        {
            if (urunler.Count == 0)
            {
                Console.WriteLine("Listede urun bulunmuyor.");
                return;
            }

            int enUcuzIndex = 0;

            for (int i = 1; i < urunler.Count; i++)
            {
                if (urunler[i].Fiyat < urunler[enUcuzIndex].Fiyat)
                {
                    enUcuzIndex = i;
                }
            }

            Console.WriteLine("\nEn ucuz urun: " + urunler[enUcuzIndex].Ad + " | Fiyat: " + urunler[enUcuzIndex].Fiyat + " TL");
        }

        static void UrunAra(string kelime)
        {
            Console.WriteLine("\n--- ARAMA SONUCLARI ---");

            bool bulundu = false;

            for (int i = 0; i < urunler.Count; i++)
            {
                if (urunler[i].Ad.ToLower().Contains(kelime.ToLower()))
                {
                    Console.WriteLine("ID: " + urunler[i].UrunId + " | Ad: " + urunler[i].Ad + " | Fiyat: " + urunler[i].Fiyat + " TL | Stok: " + urunler[i].Stok);
                    bulundu = true;
                }
            }

            if (bulundu == false)
            {
                Console.WriteLine("Aranan urune ait sonuc bulunamadi.");
            }
        }

        static void FiyatGuncelle(int id)
        {
            for (int i = 0; i < urunler.Count; i++)
            {
                if (urunler[i].UrunId == id)
                {
                    Console.WriteLine("Secilen urun: " + urunler[i].Ad + " | Mevcut fiyat: " + urunler[i].Fiyat + " TL");
                    Console.Write("Yeni fiyat girin: ");
                    string girdi = Console.ReadLine();

                    double yeniFiyat;
                    if (double.TryParse(girdi, out yeniFiyat) && yeniFiyat > 0)
                    {
                        urunler[i].Fiyat = yeniFiyat;
                        Console.WriteLine("Fiyat guncellendi. Yeni fiyat: " + urunler[i].Fiyat + " TL");
                    }
                    else
                    {
                        Console.WriteLine("Gecersiz fiyat degeri girdiniz.");
                    }
                    return;
                }
            }

            Console.WriteLine("Bu ID ile urun bulunamadi.");
        }
    }
}
